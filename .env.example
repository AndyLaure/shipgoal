# Shopify Partner Dashboard -> App -> Client credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Öffentliche URL des Render-Services (ohne Slash am Ende)
HOST=https://shipgoal.onrender.com

# Turso (Session-Speicher) – ohne diese Variablen läuft ein In-Memory-Fallback (nur für lokale Tests)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Billing-Testmodus: true = Test-Abos ohne echte Abbuchung (für Dev-Shops). Erst beim Launch auf false stellen!
BILLING_TEST=true

# Scopes: ShipGoal braucht aktuell keine (Billing + App-Metafields sind scope-frei)
SCOPES=
